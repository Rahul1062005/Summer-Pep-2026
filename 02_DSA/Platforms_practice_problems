class Solution {
public:
    void solve(stack<int> &s, int k) {
        // Middle element reached
        if (k == 1) {
            s.pop();
            return;
        }

        int temp = s.top();
        s.pop();

        solve(s, k - 1);

        s.push(temp);
    }

    void deleteMid(stack<int>& s) {
        int n = s.size();
        int k = (n / 2) + 1;   // Position of middle element from the top
        solve(s, k);
    }
};
