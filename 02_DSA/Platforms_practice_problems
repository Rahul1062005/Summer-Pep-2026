https://www.geeksforgeeks.org/problems/reverse-an-array/1

class Solution {
  public:
    void reverseArray(vector<int> &arr) {
        // code here
        int i = 0;
        int j = arr.size()-1;
        
        while (i<j){
            swap(arr[i], arr[j]);
            i++;
            j--;
        }
    }
};
