https://www.geeksforgeeks.org/problems/insert-an-element-at-the-bottom-of-a-stack/1

class Solution {
public:
    stack<int> insertAtBottom(stack<int> st, int x) {
        // Base case: if stack is empty, insert x
        if (st.empty()) {
            st.push(x);
            return st;
        }

        // Store the top element
        int temp = st.top();
        st.pop();

        // Recursively insert x at the bottom
        st = insertAtBottom(st, x);

        // Push the stored element back
        st.push(temp);

        return st;
    }
};
