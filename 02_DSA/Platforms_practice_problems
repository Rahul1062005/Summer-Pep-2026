https://leetcode.com/problems/flood-fill/submissions/2079038627/

class Solution {
public:
    void dfs(vector<vector<int>>& image, int row, int col, int original, int color)
    {
        int m = image.size();
        int n = image[0].size();

        // Base Conditions
        if(row < 0 || row >= m || col < 0 || col >= n)
            return;

        if(image[row][col] != original)
            return;

        // Paint the current cell
        image[row][col] = color;

        // Visit all 4 directions
        dfs(image, row - 1, col, original, color); // Up
        dfs(image, row + 1, col, original, color); // Down
        dfs(image, row, col - 1, original, color); // Left
        dfs(image, row, col + 1, original, color); // Right
    }

    vector<vector<int>> floodFill(vector<vector<int>>& image, int sr, int sc, int color) {

        int original = image[sr][sc];

        // If new color is same as original, nothing to do
        if(original == color)
            return image;

        dfs(image, sr, sc, original, color);

        return image;
    }
};
