https://www.geeksforgeeks.org/problems/floor-in-a-sorted-array-1587115620/1

class Solution {
public:
    int findFloor(vector<int>& arr, int x) {

        int low = 0;
        int high = arr.size() - 1;
        int ans = -1;

        while (low <= high) {

            int mid = low + (high - low) / 2;

            if (arr[mid] <= x) {
                ans = mid;        
                low = mid + 1;    
            }
            else {
                high = mid - 1;   
            }
        }

        return ans;
    }
};
