https://www.geeksforgeeks.org/problems/reverse-first-k-elements-of-queue/1

class Solution {
public:
    queue<int> reverseFirstK(queue<int> q, int k) {

        if (k > q.size())
            return q;

        stack<int> st;
        int n = q.size();

        // Step 1: Push first k elements into stack
        for (int i = 0; i < k; i++) {
            st.push(q.front());
            q.pop();
        }

        // Step 2: Push stack elements back to queue
        while (!st.empty()) {
            q.push(st.top());
            st.pop();
        }

        // Step 3: Rotate remaining n-k elements
        for (int i = 0; i < n - k; i++) {
            q.push(q.front());
            q.pop();
        }

        return q;
    }
};
