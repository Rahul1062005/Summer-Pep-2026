https://www.geeksforgeeks.org/problems/queue-reversal/1

class Solution {
public:
    void reverseQueue(queue<int> &q) {
        stack<int> st;

        // Move all elements from queue to stack
        while (!q.empty()) {
            st.push(q.front());
            q.pop();
        }

        // Move all elements back to queue
        while (!st.empty()) {
            q.push(st.top());
            st.pop();
        }
    }
};
